{
	"name": "astro.build",
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-24-trixie",
	"features": {
		"ghcr.io/devcontainers-extra/features/pnpm:2": {},
		"ghcr.io/devcontainers-extra/features/deno-asdf:2": {},
		"ghcr.io/devcontainers-extra/features/netlify-cli:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"astro-build.astro-vscode",
				"biomejs.biome",
				"unifiedjs.vscode-mdx",
				"mhutchie.git-graph"
			]
		}
	},
	"runArgs": ["--name", "astro.build"]
}
